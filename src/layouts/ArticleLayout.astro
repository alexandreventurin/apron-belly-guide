---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  breadcrumb?: { label: string; href: string }[];
}

const {
  title,
  description,
  canonicalUrl,
  breadcrumb = [],
} = Astro.props;

const canonical = canonicalUrl ?? Astro.url.href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  url: canonical,
  publisher: {
    '@type': 'Organization',
    name: 'Apron Belly Guide',
    url: 'https://apronbellyguide.com',
  },
};

const breadcrumbSchema = breadcrumb.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://apronbellyguide.com/' },
    ...breadcrumb.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: crumb.label,
      item: `https://apronbellyguide.com${crumb.href}`,
    })),
  ],
} : null;

const schemas = [
  articleSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
];
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} schema={schemas} ogType="article">
  <main class="max-w-3xl mx-auto px-4 py-10 sm:py-16">

    {breadcrumb.length > 0 && (
      <nav class="text-sm text-on-surface-variant mb-6 flex flex-wrap items-center gap-1.5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-sage-green transition-colors">Home</a>
        {breadcrumb.map((crumb) => (
          <>
            <span aria-hidden="true">›</span>
            <a href={crumb.href} class="hover:text-sage-green transition-colors">{crumb.label}</a>
          </>
        ))}
      </nav>
    )}

    <article class="prose prose-stone max-w-none
      prose-headings:font-sans prose-headings:text-on-surface
      prose-h1:text-3xl prose-h1:sm:text-4xl prose-h1:font-bold prose-h1:leading-tight prose-h1:tracking-tight prose-h1:mb-6
      prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-12 prose-h2:mb-4 prose-h2:scroll-mt-24
      prose-h3:text-xl prose-h3:font-semibold prose-h3:mt-8 prose-h3:mb-3 prose-h3:scroll-mt-24
      prose-p:text-on-surface prose-p:leading-relaxed
      prose-a:text-sage-green prose-a:no-underline hover:prose-a:underline
      prose-strong:text-on-surface
      prose-blockquote:border-sage-green prose-blockquote:text-on-surface-variant prose-blockquote:not-italic
      prose-table:text-sm prose-th:font-semibold
      prose-hr:border-neutral-muted
      prose-li:text-on-surface
      [&_details]:rounded-xl [&_details]:border [&_details]:border-neutral-muted [&_details]:bg-white [&_details]:overflow-hidden [&_details]:my-2
      [&_summary]:flex [&_summary]:items-center [&_summary]:justify-between [&_summary]:p-4 [&_summary]:cursor-pointer [&_summary]:font-semibold [&_summary]:list-none
      [&_summary_svg]:transition-transform [&_details[open]_summary_svg]:rotate-180">
      <slot />
    </article>

  </main>
</BaseLayout>
