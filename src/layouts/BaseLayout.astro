---
export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  schema?: object | object[];
  ogType?: string;
}

const {
  title,
  description,
  canonicalUrl,
  schema,
  ogType = 'website',
} = Astro.props;

const canonical = canonicalUrl ?? Astro.url.href;
const schemaJson = schema ? JSON.stringify(Array.isArray(schema) ? schema : [schema]) : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Apron Belly Guide" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Schema -->
  {schemaJson && <script type="application/ld+json" set:html={schemaJson} />}
</head>
<body class="bg-background text-on-surface font-sans antialiased">

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-background/95 backdrop-blur border-b border-neutral-muted">
    <div class="max-w-3xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="/" class="font-bold text-lg tracking-tight text-on-surface hover:text-sage-green transition-colors">
        Apron Belly Guide
      </a>
      <nav class="hidden sm:flex items-center gap-6 text-sm font-medium text-on-surface-variant">
        <a href="/non-surgical-solutions/" class="hover:text-sage-green transition-colors">Non-Surgical Guide</a>
        <a href="/compression/best-shapewear/" class="hover:text-sage-green transition-colors">Compression</a>
        <a href="/ozempic/loose-skin-after-weight-loss/" class="hover:text-sage-green transition-colors">After Ozempic</a>
        <a href="/surgery/tummy-tuck-vs-panniculectomy/" class="hover:text-sage-green transition-colors">Surgery</a>
      </nav>
      <!-- Mobile menu button (static for MVP) -->
      <button class="sm:hidden p-2 rounded-lg text-on-surface-variant hover:bg-neutral-muted transition-colors" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </header>

  <slot />

  <!-- Footer -->
  <footer class="border-t border-neutral-muted bg-background mt-16">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <div class="grid sm:grid-cols-3 gap-8 mb-10">
        <div>
          <p class="font-bold text-on-surface mb-2">Apron Belly Guide</p>
          <p class="text-sm text-on-surface-variant leading-relaxed">The practical, non-surgical guide. Written for real people, not clinics.</p>
        </div>
        <div>
          <p class="font-semibold text-sm text-on-surface mb-3">Guides</p>
          <ul class="space-y-2 text-sm text-on-surface-variant">
            <li><a href="/non-surgical-solutions/" class="hover:text-sage-green transition-colors">Non-Surgical Solutions</a></li>
            <li><a href="/compression/best-shapewear/" class="hover:text-sage-green transition-colors">Best Shapewear</a></li>
            <li><a href="/ozempic/loose-skin-after-weight-loss/" class="hover:text-sage-green transition-colors">After Ozempic</a></li>
            <li><a href="/timeline/how-long/" class="hover:text-sage-green transition-colors">Timeline Guide</a></li>
            <li><a href="/surgery/tummy-tuck-vs-panniculectomy/" class="hover:text-sage-green transition-colors">Surgery Comparison</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-sm text-on-surface mb-3">Site</p>
          <ul class="space-y-2 text-sm text-on-surface-variant">
            <li><a href="/about/" class="hover:text-sage-green transition-colors">About</a></li>
            <li><a href="/privacy/" class="hover:text-sage-green transition-colors">Privacy Policy</a></li>
            <li><a href="/terms/" class="hover:text-sage-green transition-colors">Terms of Use</a></li>
            <li><a href="mailto:contact@apronbellyguide.com" class="hover:text-sage-green transition-colors">Contact</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-neutral-muted pt-8 space-y-3 text-xs text-on-surface-variant">
        <p><strong>Affiliate Disclosure:</strong> We may earn a commission if you purchase through our links, at no extra cost to you. We only recommend products we'd suggest to a close friend.</p>
        <p><strong>Medical Disclaimer:</strong> This site is for informational purposes only and does not constitute medical advice. Consult a qualified healthcare provider before making decisions about your health.</p>
        <p>© {new Date().getFullYear()} Apron Belly Guide. All rights reserved.</p>
      </div>
    </div>
  </footer>

</body>
</html>
